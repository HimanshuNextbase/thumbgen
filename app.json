{
  "expo": {
    "name": "ThumbGen",
    "slug": "thumbgen-test",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "thumbgen",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thumbgen.app"
    },
    "android": {
      "package": "com.thumbgen.test",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F11"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
